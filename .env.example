# ── Server ─────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# Public-facing frontend base URL, used to build QR / public asset links.
FRONTEND_URL=http://localhost:5173

# ── Database ───────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# ── Auth (JWT) ─────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=24h

# ── AI (Google Gemini) ─────────────────────────────────
GEMINI_API_KEY=

# ── Media (Cloudinary) ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (SMTP, for account verification) ─────────────
# If SMTP_HOST/SMTP_USER are empty, verification emails are skipped and the
# link is logged to the server console instead (signup still works).
# Gmail example: host=smtp.gmail.com port=587 user=you@gmail.com pass=<app password>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MaintainIQ <no-reply@maintainiq.app>"
